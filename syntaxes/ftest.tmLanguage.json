{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "ftest",
    "scopeName": "source.ftest",
    "fileTypes": ["ftest"],
    "patterns": [
        {
            "name": "keyword.control.ftest",
            "match": "^\\s*(testcase_name|step\\d+)"
        },
        {
            "name": "variable.language.ftest",
            "match": "app_bat_ctx\\.voltage"
        },
        {
            "name": "constant.language.ftest",
            "match": "\\b(bat_voltage|inject_hook|delay)\\b"
        },
        {
            "name": "keyword.operator.assignment.ftest",
            "match": "="
        },
        {
            "name": "keyword.operator.comparison.ftest",
            "match": "==|<|>"
        },
        {
            "name": "constant.numeric.hex.ftest",
            "match": "0x[0-9a-fA-F]+"
        },
        {
            "name": "constant.numeric.integer.ftest",
            "match": "\\b\\d+\\b"
        },
        {
            "name": "string.quoted.single.ftest",
            "match": ":\\s*(.+)$",
            "captures": {
                "1": { "name": "string.unquoted.ftest" }
            }
        }
    ]
}